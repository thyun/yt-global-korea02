[
  {
    "text": "[संगीत]",
    "start": 1.31,
    "duration": 2.02
  },
  {
    "text": "[संगीत][गाना गाने की आवाज़]",
    "start": 5.89,
    "duration": 4.55
  },
  {
    "text": "वी",
    "start": 7.44,
    "duration": 3.0
  },
  {
    "text": "[गाना गाने की आवाज़]",
    "start": 10.48,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 13.1,
    "duration": 2.02
  },
  {
    "text": "हाय एवरीवन गुड मॉर्निंग एंड आई एम रियली",
    "start": 17.68,
    "duration": 6.32
  },
  {
    "text": "एक्साइटेड बिकॉज़ आई एम गोइंग टू बस ऑन",
    "start": 21.52,
    "duration": 5.52
  },
  {
    "text": "क्योंकि कल मेरा बर्थडे है और यह मेरा",
    "start": 24.0,
    "duration": 4.88
  },
  {
    "text": "फर्स्ट रेप होने वाला है। इससे पहले मैंने",
    "start": 27.04,
    "duration": 4.08
  },
  {
    "text": "कभी भी अपने चैनल पे बर्थडे वॉग अपलोड",
    "start": 28.88,
    "duration": 7.52
  },
  {
    "text": "नहीं किया है और इस बार कुछ स्पेशल मैंने",
    "start": 31.12,
    "duration": 8.4
  },
  {
    "text": "सोचा है अपने बर्थडे पे करने के लिए और आज",
    "start": 36.4,
    "duration": 6.24
  },
  {
    "text": "है 23 आज हम लोग जा रहे हैं भूसान में और",
    "start": 39.52,
    "duration": 6.16
  },
  {
    "text": "मेरी फ्रेंड दिस इज माय आउटफिट और नहीं",
    "start": 42.64,
    "duration": 9.0
  },
  {
    "text": "दिख रहा यह ट्रैवलिंग के लिए है सिर्फ",
    "start": 45.68,
    "duration": 5.96
  },
  {
    "text": "और यह बैग कैरी करने के लिए। यह बैग मुझे",
    "start": 55.52,
    "duration": 7.52
  },
  {
    "text": "एक्चुअली मेरी बहन ने गिफ्ट की थी जब मैं",
    "start": 60.32,
    "duration": 5.04
  },
  {
    "text": "इंडिया गई थी। उसकी फर्स्ट सैलरी का गिफ्ट",
    "start": 63.04,
    "duration": 4.8
  },
  {
    "text": "है यह। और",
    "start": 65.36,
    "duration": 4.56
  },
  {
    "text": "मैंने अपना सारा पैकिंग कर लिया है। वो",
    "start": 67.84,
    "duration": 5.36
  },
  {
    "text": "बैग वहां पे रखा है। ट्रॉली बैग तोल से भी",
    "start": 69.92,
    "duration": 5.36
  },
  {
    "text": "ज्यादा मुझे भूसान पसंद है। बिकॉज़ वहां पे",
    "start": 73.2,
    "duration": 6.48
  },
  {
    "text": "सी है। आई एम सो एक्साइटेड। तो अभी हमारा",
    "start": 75.28,
    "duration": 8.32
  },
  {
    "text": "ट्रेन है 12:00 बजे का। 12 या 12:30 का",
    "start": 79.68,
    "duration": 7.04
  },
  {
    "text": "ट्रेन है। लेकिन यहां से देन द स्टेशन एक",
    "start": 83.6,
    "duration": 4.83
  },
  {
    "text": "घंटा दूरी पर है।",
    "start": 86.72,
    "duration": 2.36
  },
  {
    "text": "[नाक से की जाने वाली आवाज़]",
    "start": 88.42,
    "duration": 1.25
  },
  {
    "text": "[गला साफ़ करने की आवाज़][खांसने की आवाज़]",
    "start": 89.08,
    "duration": 2.84
  },
  {
    "text": "कोल्ड हो गया।",
    "start": 89.68,
    "duration": 4.8
  },
  {
    "text": "उससे पहले मुझे ना कॉफी पीने का मन कर रहा",
    "start": 91.92,
    "duration": 5.04
  },
  {
    "text": "है। मतलब मन तो नहीं। सुबह-सुबह कॉफी पीना",
    "start": 94.48,
    "duration": 4.8
  },
  {
    "text": "मुझे अभी पड़ेगा ही। अदरवाइज मुझे बहुत",
    "start": 96.96,
    "duration": 4.88
  },
  {
    "text": "नींद आएगी। तो हम लोग फटाफट से कॉफी लेते",
    "start": 99.28,
    "duration": 5.92
  },
  {
    "text": "हैं। एंड ये सारा बैग वगैरह लेके मुझे",
    "start": 101.84,
    "duration": 5.28
  },
  {
    "text": "मेरी फ्रेंड के यहां जाना है। वहां से हम",
    "start": 105.2,
    "duration": 4.08
  },
  {
    "text": "लोग या तो टैक्सी लेंगे अगर लेट हो गया तो",
    "start": 107.12,
    "duration": 6.92
  },
  {
    "text": "या फिर बस लेंगे। तो लेट्स गो।",
    "start": 109.28,
    "duration": 4.76
  },
  {
    "text": "दिस इज आइस एंड दिस वन इज हॉट आइस फॉर मी",
    "start": 136.16,
    "duration": 8.68
  },
  {
    "text": "और हॉट मेरी फ्रेंड के लिए है।",
    "start": 140.48,
    "duration": 4.36
  },
  {
    "text": "से",
    "start": 193.2,
    "duration": 3.0
  },
  {
    "text": "फाइनली हम हम लोग पहुंचे हैं यहां भूसान",
    "start": 224.0,
    "duration": 8.4
  },
  {
    "text": "स्टेशन पे और ये हमारे साथ में है सौम्या",
    "start": 226.56,
    "duration": 9.04
  },
  {
    "text": "हम लोग इतने ज्यादा थक चुके हैं ना दोद",
    "start": 232.4,
    "duration": 7.12
  },
  {
    "text": "हजारों ट्रेन बदल के मतलब पूरा",
    "start": 235.6,
    "duration": 6.8
  },
  {
    "text": "दो ट्रेन बदली हमने सुबह से हमने कुछ खाया",
    "start": 239.52,
    "duration": 6.08
  },
  {
    "text": "नहीं है क्योंकि 10:30 बजे हम लोग निकले",
    "start": 242.4,
    "duration": 6.96
  },
  {
    "text": "थे घर से और सुबह-सुबह ऐसे कुछ भाजा नहीं",
    "start": 245.6,
    "duration": 7.28
  },
  {
    "text": "है तो सिर्फ कॉन्फ्लिक्ट्स खाया उसके बाद",
    "start": 249.36,
    "duration": 6.16
  },
  {
    "text": "जो हमारा जर्नी स्टार्ट हुआ है। अभी बजे",
    "start": 252.88,
    "duration": 5.12
  },
  {
    "text": "हैं यहां पे 5:30 और अभी भी खत्म नहीं हुआ",
    "start": 255.52,
    "duration": 4.72
  },
  {
    "text": "है। अभी हमें रूम तक जाना है। उसके लिए",
    "start": 258.0,
    "duration": 6.08
  },
  {
    "text": "हमें बस लेना है। देन थोड़ा सा रेडी होना",
    "start": 260.24,
    "duration": 7.36
  },
  {
    "text": "है और उसके बाद हम लोग जाएंगे एक फेमस",
    "start": 264.08,
    "duration": 6.08
  },
  {
    "text": "स्ट्रीट है यहां पे। वहां जाके हम कुछ",
    "start": 267.6,
    "duration": 5.56
  },
  {
    "text": "खाएंगे।",
    "start": 270.16,
    "duration": 3.0
  },
  {
    "text": "मुझे ऐसा लगता है कि इस वीकेंड ना सारे",
    "start": 276.56,
    "duration": 4.08
  },
  {
    "text": "लोग वो साल आ गए हैं। बिकॉज़ यहां पे मंडे",
    "start": 278.64,
    "duration": 3.76
  },
  {
    "text": "का भी हॉलिडे है। तो सैटरडे, संडे एंड",
    "start": 280.64,
    "duration": 4.76
  },
  {
    "text": "मंडे।",
    "start": 282.4,
    "duration": 3.0
  },
  {
    "text": "आई मीन ये प्लेस क्राउडेड नहीं लग रहा",
    "start": 285.6,
    "duration": 5.52
  },
  {
    "text": "लेकिन मुझे सामने बस स्टॉप है ना वहां पे",
    "start": 287.68,
    "duration": 8.52
  },
  {
    "text": "आगे बहुत सारे लोग हैं",
    "start": 291.12,
    "duration": 5.08
  },
  {
    "text": "और हम आ गए वो साल",
    "start": 296.88,
    "duration": 9.0
  },
  {
    "text": "वो साल की तो हवा ही अलग है",
    "start": 301.28,
    "duration": 4.6
  },
  {
    "text": "वैसे यहां पे आज मैंने पहली बार होमलेस",
    "start": 309.36,
    "duration": 3.76
  },
  {
    "text": "देखे",
    "start": 311.6,
    "duration": 6.8
  },
  {
    "text": "क्या हां भूसान का हम",
    "start": 313.12,
    "duration": 9.16
  },
  {
    "text": "भूसान इज़ गुड",
    "start": 318.4,
    "duration": 3.88
  },
  {
    "text": "भूसान इज़ गुड",
    "start": 323.36,
    "duration": 3.96
  },
  {
    "text": "सी कितना ज्यादा क्राउडेड है।",
    "start": 328.32,
    "duration": 4.84
  },
  {
    "text": "एक्चुअली बुलसानी इज परफेक्ट। इनको यहां",
    "start": 333.44,
    "duration": 6.28
  },
  {
    "text": "पे चेंज करना चाहिए।",
    "start": 335.92,
    "duration": 3.8
  },
  {
    "text": "जॉइ करने का मन कर रहा है उनको",
    "start": 355.92,
    "duration": 4.36
  },
  {
    "text": "हम ओ ये क्या हम लोग अभी जस्ट रूम में",
    "start": 361.04,
    "duration": 6.08
  },
  {
    "text": "पहुंचे हैं और यहां पे सबसे पहले आने से",
    "start": 364.16,
    "duration": 5.6
  },
  {
    "text": "मतलब आते ही हमने कैमरा चेक करने का काम",
    "start": 367.12,
    "duration": 5.04
  },
  {
    "text": "शुरू किया है। बिकॉज़ ऐसे कहते हैं कि यहां",
    "start": 369.76,
    "duration": 5.2
  },
  {
    "text": "पे होटल्स में इसको क्या कहते हैं? स्पाई",
    "start": 372.16,
    "duration": 5.8
  },
  {
    "text": "कैमरास।",
    "start": 374.96,
    "duration": 3.0
  },
  {
    "text": "क्या आया?",
    "start": 379.28,
    "duration": 3.32
  },
  {
    "text": "तो इसका एक ऐप है। वहां से हम लोग डिटेक्ट",
    "start": 383.6,
    "duration": 6.16
  },
  {
    "text": "कर रहे हैं कि कोई कैमरा तो नहीं है। हिडन",
    "start": 387.68,
    "duration": 4.64
  },
  {
    "text": "कैमरा या कुछ भी।",
    "start": 389.76,
    "duration": 6.08
  },
  {
    "text": "तो सारा हमने लाइट्स ऑफ किया। विंडज़ क्लोज",
    "start": 392.32,
    "duration": 8.32
  },
  {
    "text": "किया और इस ऐप से हम देख रहे हैं।",
    "start": 395.84,
    "duration": 4.8
  },
  {
    "text": "अभी हम लोगों ने चेंज किया है और मेरा जो",
    "start": 405.12,
    "duration": 5.36
  },
  {
    "text": "रिसीवर था माइक का वो गिर गया मुझसे बस",
    "start": 407.44,
    "duration": 5.92
  },
  {
    "text": "में",
    "start": 410.48,
    "duration": 7.16
  },
  {
    "text": "इतना दिल दुख रहा है ना मेरा",
    "start": 413.36,
    "duration": 4.28
  },
  {
    "text": "आते ही नुकसान",
    "start": 418.0,
    "duration": 2.96
  },
  {
    "text": "यस आते ही नुकसान",
    "start": 419.36,
    "duration": 3.76
  },
  {
    "text": "इतना बड़ा नुकसान हुआ है कि मैं उभर ही",
    "start": 420.96,
    "duration": 5.92
  },
  {
    "text": "नहीं पा रही [हंसी] खुशी नहीं हो रहा मुझे",
    "start": 423.12,
    "duration": 6.4
  },
  {
    "text": "लेकिन सब चीजों को साइड रखते हुए अभी हम",
    "start": 426.88,
    "duration": 4.72
  },
  {
    "text": "जा रहे हैं नामो स्ट्रीट ना",
    "start": 429.52,
    "duration": 5.52
  },
  {
    "text": "नामपो स्ट्रीट और मैंने ये सा आउटफिट पहना",
    "start": 431.6,
    "duration": 6.44
  },
  {
    "text": "है",
    "start": 435.04,
    "duration": 3.0
  },
  {
    "text": "तो ये है नाम स्ट्रीट",
    "start": 438.08,
    "duration": 5.08
  },
  {
    "text": "तो हम आए हैं वो सन के डाउन टाउन है।",
    "start": 455.52,
    "duration": 6.56
  },
  {
    "text": "यहां पे बहुत सारी चीजें हैं लेकिन हम",
    "start": 460.24,
    "duration": 5.32
  },
  {
    "text": "नहीं खा सकते।",
    "start": 462.08,
    "duration": 3.48
  },
  {
    "text": "[संगीत]",
    "start": 477.5,
    "duration": 2.02
  },
  {
    "text": "आज बुद्ध भगवान जी का शायद बर्थडे है। इस",
    "start": 479.68,
    "duration": 5.2
  },
  {
    "text": "वजह से पूरा स्वीट ऐसे डेकोरेट किया है।",
    "start": 482.24,
    "duration": 7.08
  },
  {
    "text": "उन पे वो बना हुआ भी है।",
    "start": 484.88,
    "duration": 4.44
  },
  {
    "text": "अभी हम जा रहे हैं खाना खाने के लिए और हम",
    "start": 491.12,
    "duration": 7.28
  },
  {
    "text": "शायद कोरियन रेस्टोरेंट जा रहे हैं। अगर",
    "start": 495.44,
    "duration": 5.6
  },
  {
    "text": "वहां पे कुछ वेज हुआ तो हम वो खाएंगे।",
    "start": 498.4,
    "duration": 4.8
  },
  {
    "text": "अदरवाइज यहां पे एक इंडियन रेस्टोरेंट भी",
    "start": 501.04,
    "duration": 7.0
  },
  {
    "text": "है। वो भी ट्राई कर सकते हैं।",
    "start": 503.2,
    "duration": 4.84
  },
  {
    "text": "लाइट चेक",
    "start": 517.84,
    "duration": 3.4
  },
  {
    "text": "ऐसी साइड डिशेस होती है",
    "start": 527.36,
    "duration": 4.36
  },
  {
    "text": "ये सारी हम नहीं खा सकते क्योंकि किसी",
    "start": 532.32,
    "duration": 3.36
  },
  {
    "text": "नॉनवेज",
    "start": 534.16,
    "duration": 4.08
  },
  {
    "text": "हम खाएंगे मिर्ची",
    "start": 535.68,
    "duration": 4.88
  },
  {
    "text": "और ये है चुकंबर",
    "start": 538.24,
    "duration": 3.6
  },
  {
    "text": "पिकल",
    "start": 540.56,
    "duration": 4.64
  },
  {
    "text": "हां इट्स अ काइंड ऑफ़ पिकल और ये क्या है",
    "start": 541.84,
    "duration": 4.24
  },
  {
    "text": "गोजू जंग",
    "start": 545.2,
    "duration": 4.24
  },
  {
    "text": "हम ये गोजू जंग है यहां पे स्पाइसी पेस्ट",
    "start": 546.08,
    "duration": 6.44
  },
  {
    "text": "है ये",
    "start": 549.44,
    "duration": 3.08
  },
  {
    "text": "साविदा",
    "start": 570.72,
    "duration": 3.0
  },
  {
    "text": "हाथ छूट रहा है इसमें से",
    "start": 583.6,
    "duration": 4.2
  },
  {
    "text": "मैंने नेल्स हटा दिए",
    "start": 595.6,
    "duration": 4.88
  },
  {
    "text": "क्योंकि वो मेरे किसी भी आउटफिट के साथ",
    "start": 598.72,
    "duration": 5.64
  },
  {
    "text": "मैच नहीं हो रहे थे।",
    "start": 600.48,
    "duration": 3.88
  },
  {
    "text": "थैंक",
    "start": 617.04,
    "duration": 3.0
  },
  {
    "text": "हम लोग यहां पे कोरियन आए हैं",
    "start": 638.4,
    "duration": 9.68
  },
  {
    "text": "वहां पे लाइन लगी है पहले ही यहां पे कैश",
    "start": 642.72,
    "duration": 9.96
  },
  {
    "text": "में लाइन लगी",
    "start": 648.08,
    "duration": 4.6
  },
  {
    "text": "कैसे",
    "start": 653.76,
    "duration": 3.0
  },
  {
    "text": "बट बहुत टेस्टी होता है। ये दूस पहली बार",
    "start": 663.6,
    "duration": 3.68
  },
  {
    "text": "खाई ना",
    "start": 666.4,
    "duration": 2.96
  },
  {
    "text": "फर्स्ट टाइम मैंने पहली बार ये दूसरी बार",
    "start": 667.28,
    "duration": 3.12
  },
  {
    "text": "ही है ओवर",
    "start": 669.36,
    "duration": 2.64
  },
  {
    "text": "यहां आने के बाद मैं सेकंड टाइम ही खाने",
    "start": 670.4,
    "duration": 3.28
  },
  {
    "text": "वाली हूं ये। पहली बार भी मैंने खिलाया",
    "start": 672.0,
    "duration": 4.32
  },
  {
    "text": "था। फेज वन में खाया था हमने और वो भी",
    "start": 673.68,
    "duration": 5.52
  },
  {
    "text": "बहुत डिलीशियस था। ये मस्त है। तो मैंने",
    "start": 676.32,
    "duration": 4.64
  },
  {
    "text": "फर्स्ट टाइम खाया था। तो वो भी अच्छा लग",
    "start": 679.2,
    "duration": 3.04
  },
  {
    "text": "रहा था मुझे।",
    "start": 680.96,
    "duration": 5.04
  },
  {
    "text": "अभी इसको खा के रिव्यु दूंगी। रेट करना",
    "start": 682.24,
    "duration": 7.2
  },
  {
    "text": "रेट रेडिंग करूंगी।",
    "start": 686.0,
    "duration": 7.2
  },
  {
    "text": "ये हद तक बनने का प्रोसेस तेल में डूबे",
    "start": 689.44,
    "duration": 5.28
  },
  {
    "text": "हुए",
    "start": 693.2,
    "duration": 5.2
  },
  {
    "text": "ये तेल है बट नहीं है। मैं भी यही सोची थी",
    "start": 694.72,
    "duration": 7.56
  },
  {
    "text": "आप लोगों की तरह की है।",
    "start": 698.4,
    "duration": 3.88
  },
  {
    "text": "ऑइल",
    "start": 703.36,
    "duration": 5.8
  },
  {
    "text": "इसके अंदर फीलिंग क्या होती है?",
    "start": 705.04,
    "duration": 4.12
  },
  {
    "text": "की फीलिंग है।",
    "start": 709.6,
    "duration": 3.48
  },
  {
    "text": "आने वाले",
    "start": 715.76,
    "duration": 3.32
  },
  {
    "text": "पूरा नर्स है इसके अंदर",
    "start": 730.24,
    "duration": 4.04
  },
  {
    "text": "ये मुझे ज्यादा डिलीशियस लग रहा है नहीं",
    "start": 737.6,
    "duration": 5.28
  },
  {
    "text": "जलने वाले स्मेल करो सिर्फ",
    "start": 739.52,
    "duration": 4.96
  },
  {
    "text": "क्या",
    "start": 742.88,
    "duration": 5.12
  },
  {
    "text": "आप लोग भी अगर आप इंसान में आओ तो ये ना",
    "start": 744.48,
    "duration": 5.76
  },
  {
    "text": "आपको नापो",
    "start": 748.0,
    "duration": 5.26
  },
  {
    "text": "स्ट्रीट है यहां पर आके हद तक जरूर खाना",
    "start": 750.24,
    "duration": 4.32
  },
  {
    "text": "[हंसी]",
    "start": 753.26,
    "duration": 4.66
  },
  {
    "text": "हद तक जरूर खाना ओके ये कोरियन ट्रेडिशनल",
    "start": 754.56,
    "duration": 5.52
  },
  {
    "text": "स्वीट है यहां का जैसे हमारे यहां",
    "start": 757.92,
    "duration": 6.6
  },
  {
    "text": "रसगुल्ला और गुलाब जामुन होता है",
    "start": 760.08,
    "duration": 4.44
  },
  {
    "text": "ये क्रिस्पी है",
    "start": 768.8,
    "duration": 6.28
  },
  {
    "text": "वो वाला क्रिस्पी भी नहीं था।",
    "start": 770.96,
    "duration": 4.12
  },
  {
    "text": "इसके साथ बहुत मस्त है।",
    "start": 776.08,
    "duration": 6.48
  },
  {
    "text": "डिलीशियस",
    "start": 779.68,
    "duration": 5.92
  },
  {
    "text": "इसको मैं रेड करूंगी। न आउट 10",
    "start": 782.56,
    "duration": 3.84
  },
  {
    "text": "एक क्यों काटा था?",
    "start": 785.6,
    "duration": 3.76
  },
  {
    "text": "क्योंकि ऑइल में बनाना है।",
    "start": 786.4,
    "duration": 7.4
  },
  {
    "text": "थोड़ा सा मैं हेल्थ फ्री हो रही हूं अभी।",
    "start": 789.36,
    "duration": 4.44
  },
  {
    "text": "बहुत यम्मी",
    "start": 796.72,
    "duration": 5.52
  },
  {
    "text": "ये स्वीट भी है सॉल्टी भी है थोड़ा सा",
    "start": 799.76,
    "duration": 3.84
  },
  {
    "text": "इसलिए ज्यादा अच्छा लग रहा है",
    "start": 802.24,
    "duration": 2.48
  },
  {
    "text": "बाकी लोग ना",
    "start": 803.6,
    "duration": 3.52
  },
  {
    "text": "हम लाइक यहां के अलावा कोरिया में",
    "start": 804.72,
    "duration": 3.52
  },
  {
    "text": "पैनकेक की तरह",
    "start": 807.12,
    "duration": 2.4
  },
  {
    "text": "वो लोग नमक डालते हो",
    "start": 808.24,
    "duration": 2.48
  },
  {
    "text": "और दूसरा चीज ये है जो",
    "start": 809.52,
    "duration": 2.8
  },
  {
    "text": "लोग जरूर नमक डालते हैं थोड़ा",
    "start": 810.72,
    "duration": 3.2
  },
  {
    "text": "और जो मैंने फर्स्ट टाइम खाया था वो",
    "start": 812.32,
    "duration": 3.36
  },
  {
    "text": "पैनकेक की तरह लग रहा था। इतना क्रिस्पी",
    "start": 813.92,
    "duration": 2.4
  },
  {
    "text": "नहीं था।",
    "start": 815.68,
    "duration": 5.96
  },
  {
    "text": "ये एकदम क्रिस्पी है। मस्त है।",
    "start": 816.32,
    "duration": 5.32
  },
  {
    "text": "हम लोग अभी शॉपिंग के लिए आए हैं।",
    "start": 826.32,
    "duration": 4.52
  },
  {
    "text": "शॉपिंग में चल रहा है लेकिन सब कुछ इतना",
    "start": 833.68,
    "duration": 6.88
  },
  {
    "text": "ज्यादा एक्सपेंसिव है ना यहां पे और",
    "start": 836.24,
    "duration": 8.16
  },
  {
    "text": "इसका फैसल आई मीन फैशन [हंसी]",
    "start": 840.56,
    "duration": 6.08
  },
  {
    "text": "इतना कूल नहीं लग रहा मुझे क्योंकि मेरा",
    "start": 844.4,
    "duration": 6.92
  },
  {
    "text": "माइक का रिसीवर गुम हो गया है।",
    "start": 846.64,
    "duration": 4.68
  },
  {
    "text": "राइटिंग अच्छा है। [संगीत]",
    "start": 851.6,
    "duration": 3.24
  },
  {
    "text": "कुछ भी होश नहीं रुकना चाहिए।",
    "start": 854.96,
    "duration": 5.78
  },
  {
    "text": "[गाना गाने की आवाज़]",
    "start": 858.71,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 861.33,
    "duration": 2.02
  },
  {
    "text": "वाइट या ब्लैक ब्लैक",
    "start": 867.84,
    "duration": 4.68
  },
  {
    "text": "[संगीत]",
    "start": 875.09,
    "duration": 5.19
  },
  {
    "text": "अच्छा लगेगा ना",
    "start": 876.56,
    "duration": 3.72
  },
  {
    "text": "[संगीत]",
    "start": 883.61,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 899.98,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 906.53,
    "duration": 2.02
  },
  {
    "text": "कैसे",
    "start": 912.0,
    "duration": 3.0
  },
  {
    "text": "अच्छा लग रहा है ना? मस्त लग रहा है। वैसे",
    "start": 923.92,
    "duration": 5.68
  },
  {
    "text": "मुझे ट्यूलिप पसंद है लेकिन आज यहां पे",
    "start": 927.52,
    "duration": 6.76
  },
  {
    "text": "ट्यूलिप था नहीं तो मुझे ये लेना पड़ा।",
    "start": 929.6,
    "duration": 4.68
  },
  {
    "text": "ये मेरी ड्रेस के साथ बिलकुल परफेक्ट जा",
    "start": 937.2,
    "duration": 4.0
  },
  {
    "text": "रहा है।",
    "start": 939.12,
    "duration": 4.64
  },
  {
    "text": "एंड हैप्पी बर्थडे टू मी। अभी वन ऑवर के",
    "start": 941.2,
    "duration": 5.28
  },
  {
    "text": "बाद मेरा बर्थडे है।",
    "start": 943.76,
    "duration": 6.28
  },
  {
    "text": "प्लीज आजा।",
    "start": 946.48,
    "duration": 3.56
  },
  {
    "text": "क्या",
    "start": 951.12,
    "duration": 3.0
  },
  {
    "text": "[संगीत]",
    "start": 954.35,
    "duration": 5.54
  },
  {
    "text": "फाइनली पहुंच गए",
    "start": 956.0,
    "duration": 3.88
  },
  {
    "text": "कितना प्रीटी लग रहा है",
    "start": 962.32,
    "duration": 5.76
  },
  {
    "text": "अभी हम अच्छा पॉइंट ढूंढ रहे हैं यहां पे",
    "start": 965.92,
    "duration": 4.88
  },
  {
    "text": "ताकि मैं अपना केक कट कर सकूं लेकिन हमें",
    "start": 968.08,
    "duration": 4.64
  },
  {
    "text": "मिल नहीं रहा है कोई अच्छा पॉइंट शायद",
    "start": 970.8,
    "duration": 6.12
  },
  {
    "text": "हमें बीच ही चेंज करना पड़ेगा",
    "start": 972.72,
    "duration": 4.2
  },
  {
    "text": "आई होप इस बार जल जाए। ये हमारा",
    "start": 984.0,
    "duration": 10.6
  },
  {
    "text": "2000 वाला ट्राई है। हैप्पी बर्थडे टू मी।",
    "start": 987.92,
    "duration": 6.68
  },
  {
    "text": "बर्थडे टू यू। हैप्पी बर्थडे डअ डूई।",
    "start": 994.88,
    "duration": 6.64
  },
  {
    "text": "हैप्पी बर्थडे टू यू। हे भगवान जी मेरा",
    "start": 998.64,
    "duration": 5.88
  },
  {
    "text": "सारा",
    "start": 1001.52,
    "duration": 3.0
  },
  {
    "text": "हैप्पी बर्थडे हैप्पी बर्थडे",
    "start": 1005.12,
    "duration": 7.04
  },
  {
    "text": "हम आए हैं समोसे के पास देखो पीछे नहरे चल",
    "start": 1008.8,
    "duration": 7.2
  },
  {
    "text": "रही है जो कि मेरा सबसे पुराना सपना था",
    "start": 1012.16,
    "duration": 6.24
  },
  {
    "text": "मतलब मैं छोटी थी ना तब से मैं चाहती थी",
    "start": 1016.0,
    "duration": 4.72
  },
  {
    "text": "कि मैं सी के पास अपना बर्थडे बनाऊं जब",
    "start": 1018.4,
    "duration": 4.24
  },
  {
    "text": "मैं छोटी थी तब से ऐसा सोच रही थी कि मैं",
    "start": 1020.72,
    "duration": 5.2
  },
  {
    "text": "सी के पास अपना बर्थडे बनाऊंगी और जाके",
    "start": 1022.64,
    "duration": 6.56
  },
  {
    "text": "पूरा हुआ थैंक यू",
    "start": 1025.92,
    "duration": 5.2
  },
  {
    "text": "थैंक यू",
    "start": 1029.2,
    "duration": 7.28
  },
  {
    "text": "हैप्पी बर्थडे। हेलो हैप्पी बर्थडे।",
    "start": 1031.12,
    "duration": 8.48
  },
  {
    "text": "थैंक यू।",
    "start": 1036.48,
    "duration": 6.0
  },
  {
    "text": "आपका मेरा मेरा आशुदाना आपके साथ है।",
    "start": 1039.6,
    "duration": 4.8
  },
  {
    "text": "शुक्रिया।",
    "start": 1042.48,
    "duration": 5.76
  },
  {
    "text": "कितना रिलैक्सिंग है यार।",
    "start": 1044.4,
    "duration": 6.4
  },
  {
    "text": "वहां पे बैठे थे। इतनी ज्यादा हमें ठंड",
    "start": 1048.24,
    "duration": 5.04
  },
  {
    "text": "लगने लगी थी। इतनी ज्यादा किल ऐसे होने लग",
    "start": 1050.8,
    "duration": 5.44
  },
  {
    "text": "गया था। तो अभी हम यहां पे कॉफी लेने के",
    "start": 1053.28,
    "duration": 4.96
  },
  {
    "text": "लिए आए हैं। इतनी ज्यादा यहां पे रात हो",
    "start": 1056.24,
    "duration": 3.28
  },
  {
    "text": "रही है और",
    "start": 1058.24,
    "duration": 3.2
  },
  {
    "text": "रात नहीं हो रहा। दिन हो रहा है।",
    "start": 1059.52,
    "duration": 2.8
  },
  {
    "text": "देखो दिन हो रहा है।",
    "start": 1061.44,
    "duration": 2.88
  },
  {
    "text": "देखो सुबह हो रही है और हमें बहुत ठंड लग",
    "start": 1062.32,
    "duration": 4.0
  },
  {
    "text": "रही है। लेकिन फिर भी यहां पे सब कुछ ओपन",
    "start": 1064.32,
    "duration": 5.52
  },
  {
    "text": "है लाइक दिस। ये कॉफी शॉप खुला हुआ है। अब",
    "start": 1066.32,
    "duration": 7.64
  },
  {
    "text": "हम गरम-गरम सी कॉफी लेंगे।",
    "start": 1069.84,
    "duration": 4.12
  },
  {
    "text": "नहीं लेना।",
    "start": 1076.32,
    "duration": 3.4
  },
  {
    "text": "सी",
    "start": 1080.88,
    "duration": 3.0
  },
  {
    "text": "अभी मैं इसके पीछे का स्टोरी बताऊं आप",
    "start": 1084.32,
    "duration": 4.16
  },
  {
    "text": "लोगों को। हम बर्थडे सेलिब्रेट करने के",
    "start": 1086.4,
    "duration": 5.84
  },
  {
    "text": "लिए सी पे आए हैं और हम केक, कैंडल्स सब",
    "start": 1088.48,
    "duration": 6.0
  },
  {
    "text": "लाना भूल गए थे। जैसे तेज से जैसे हमने",
    "start": 1092.24,
    "duration": 4.72
  },
  {
    "text": "अरेंज किया। अभी हम यहां आए तो मालूम चल",
    "start": 1094.48,
    "duration": 4.64
  },
  {
    "text": "रहा है कि यहां तो सब कुछ मिल रहा है। सी",
    "start": 1096.96,
    "duration": 4.8
  },
  {
    "text": "के पास ही ये कैफे है। कैंडल भी हमने",
    "start": 1099.12,
    "duration": 4.4
  },
  {
    "text": "कैंडल जीएस से लिया है।",
    "start": 1101.76,
    "duration": 3.12
  },
  {
    "text": "3000 का।",
    "start": 1103.52,
    "duration": 3.28
  },
  {
    "text": "जीएस से कैंडल लिया है। हैप्पी बर्थडे का।",
    "start": 1104.88,
    "duration": 4.48
  },
  {
    "text": "उसमें से आ ही मैंने यूज़ किया है। पूरा",
    "start": 1106.8,
    "duration": 4.4
  },
  {
    "text": "लगा नहीं सकते थे क्योंकि वो पेस्ट इतना",
    "start": 1109.36,
    "duration": 3.6
  },
  {
    "text": "सा था। [संगीत]",
    "start": 1111.2,
    "duration": 5.12
  },
  {
    "text": "ऐसी अजीबोगरीब चीजें हमारे साथ क्यों हो",
    "start": 1112.96,
    "duration": 6.08
  },
  {
    "text": "रही है सुबह से? मैं कह रही हूं उन आंटी",
    "start": 1116.32,
    "duration": 5.44
  },
  {
    "text": "की वजह से हो रही है। [हंसी] एक आंटी मिले",
    "start": 1119.04,
    "duration": 4.8
  },
  {
    "text": "थे। इनकी बिल्डिंग में एक आंटी मिले थे।",
    "start": 1121.76,
    "duration": 3.68
  },
  {
    "text": "उन्होंने",
    "start": 1123.84,
    "duration": 4.0
  },
  {
    "text": "जो हमारे साथ आज सुबह से हमारे साथ सब कुछ",
    "start": 1125.44,
    "duration": 6.76
  },
  {
    "text": "लेट हो रहा है। वो शामिल है।",
    "start": 1127.84,
    "duration": 4.36
  },
  {
    "text": "कॉफी लेते हैं। अभी अरे यार दुख हो रही है",
    "start": 1133.36,
    "duration": 4.16
  },
  {
    "text": "मुझे।",
    "start": 1137.12,
    "duration": 2.56
  },
  {
    "text": "सीरियसली मुझे भी दुख हो रहा है। कैंडल",
    "start": 1137.52,
    "duration": 2.72
  },
  {
    "text": "देख के दुख हो रहा है।",
    "start": 1139.68,
    "duration": 1.92
  },
  {
    "text": "बट ठीक-ठाक।",
    "start": 1140.24,
    "duration": 2.56
  },
  {
    "text": "कैंडल देख के",
    "start": 1141.6,
    "duration": 3.04
  },
  {
    "text": "बस कैंडल देख के ही हो रहा है मुझे।",
    "start": 1142.8,
    "duration": 6.44
  },
  {
    "text": "क्योंकि वो तो अच्छा था हमने जो लिया था।",
    "start": 1144.64,
    "duration": 4.6
  },
  {
    "text": "[संगीत]",
    "start": 1154.12,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 1158.71,
    "duration": 4.01
  },
  {
    "text": "काफी टाइम के बाद मैं हॉट कॉफी लेने वाली",
    "start": 1160.56,
    "duration": 6.32
  },
  {
    "text": "हूं। नहीं टी नहीं फंबल हो रहा है। रात के",
    "start": 1162.72,
    "duration": 6.0
  },
  {
    "text": "2:00 बज [संगीत] रहे हैं। बहुत नींद आ रही",
    "start": 1166.88,
    "duration": 4.96
  },
  {
    "text": "है। सो फाइनली मैं बहुत टाइम के बाद हॉट",
    "start": 1168.72,
    "duration": 5.36
  },
  {
    "text": "टी लेने वाली हूं। मैंने लिया है हनी",
    "start": 1171.84,
    "duration": 4.64
  },
  {
    "text": "बल्स। आई डोंट नो कैसा होगा। फर्स्ट टाइम",
    "start": 1174.08,
    "duration": 5.6
  },
  {
    "text": "है मेरा और ये टैबू भी मुझे खास ज्यादा",
    "start": 1176.48,
    "duration": 5.52
  },
  {
    "text": "पसंद नहीं है। हॉल क्रॉस करके। [संगीत]",
    "start": 1179.68,
    "duration": 4.4
  },
  {
    "text": "लेट्स सी। इसका कॉफी पसंद नहीं है। टी कभी",
    "start": 1182.0,
    "duration": 3.92
  },
  {
    "text": "ट्राई नहीं किया मैंने।",
    "start": 1184.08,
    "duration": 3.84
  },
  {
    "text": "यहां पे जब भी हम कुछ भी कॉफी ऑर्डर करते",
    "start": 1185.92,
    "duration": 4.08
  },
  {
    "text": "हैं तो वो साथ में यह देते हैं। जैसे ही",
    "start": 1187.92,
    "duration": 4.72
  },
  {
    "text": "आपका डन आपका ऑर्डर रेडी होता है तो यह",
    "start": 1190.0,
    "duration": 5.28
  },
  {
    "text": "ब्रदर साउंड करते हैं। तब आपको ये लेके",
    "start": 1192.64,
    "duration": 5.04
  },
  {
    "text": "जाना है। उनको देना है और आपको कॉफी मिल",
    "start": 1195.28,
    "duration": 5.44
  },
  {
    "text": "जाएगा। तभी देखना मेरा कॉफी रेडी हुआ है।",
    "start": 1197.68,
    "duration": 5.52
  },
  {
    "text": "सॉरी टी रेडी हुआ है। तो अभी इसमें से",
    "start": 1200.72,
    "duration": 6.92
  },
  {
    "text": "साउंड आएगा और लाइट भी लगता है।",
    "start": 1203.2,
    "duration": 4.44
  },
  {
    "text": "[संगीत]",
    "start": 1207.83,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 1213.07,
    "duration": 2.02
  },
  {
    "text": "[संगीत]",
    "start": 1223.55,
    "duration": 2.02
  },
  {
    "text": "दिस इज़ माय हनी एंड दिस इज़ सौम्यास।",
    "start": 1227.12,
    "duration": 3.36
  },
  {
    "text": "[संगीत]",
    "start": 1229.46,
    "duration": 3.98
  },
  {
    "text": "दोनों ने टी ऑर्डर किया है बिकॉज़ वैसे तो",
    "start": 1230.48,
    "duration": 5.92
  },
  {
    "text": "मैं यूजुअली आई पीती हूं लेकिन यहां पे जो",
    "start": 1233.44,
    "duration": 5.44
  },
  {
    "text": "जुकाम लगेगा ना हमें तो मुझे हॉट पीना",
    "start": 1236.4,
    "duration": 6.2
  },
  {
    "text": "बहुत जरूरी है।",
    "start": 1238.88,
    "duration": 3.72
  },
  {
    "text": "[संगीत]",
    "start": 1243.2,
    "duration": 2.02
  },
  {
    "text": "वो क्यों बोल रही है?",
    "start": 1250.56,
    "duration": 2.4
  },
  {
    "text": "मुझे ये वर्ड आता है।",
    "start": 1251.84,
    "duration": 2.4
  },
  {
    "text": "क्यों बोलता है?",
    "start": 1252.96,
    "duration": 4.65
  },
  {
    "text": "क्या बोलूं? वेलकम को क्या कहते हैं?",
    "start": 1254.24,
    "duration": 5.12
  },
  {
    "text": "[संगीत]",
    "start": 1257.61,
    "duration": 4.75
  },
  {
    "text": "से",
    "start": 1259.36,
    "duration": 3.0
  },
  {
    "text": "इधर तो मिला नहीं। आगे जाके",
    "start": 1264.88,
    "duration": 4.28
  },
  {
    "text": "नॉट बैड। अच्छा है।",
    "start": 1277.84,
    "duration": 3.76
  },
  {
    "text": "[संगीत]",
    "start": 1280.54,
    "duration": 3.38
  },
  {
    "text": "तो आज के लिए बस इतना ही। अभी मिलते हैं",
    "start": 1281.6,
    "duration": 5.28
  },
  {
    "text": "कल।",
    "start": 1283.92,
    "duration": 2.96
  }
]
